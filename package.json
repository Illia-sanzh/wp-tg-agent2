{
  "name": "greenclaw-agent",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "agent",
    "telegram-bot"
  ],
  "scripts": {
    "lint": "eslint \"agent/**/*.ts\" \"telegram-bot/**/*.ts\" --ignore-pattern \"**/node_modules\" --ignore-pattern \"**/dist\"",
    "lint:fix": "eslint --fix \"agent/**/*.ts\" \"telegram-bot/**/*.ts\" --ignore-pattern \"**/node_modules\" --ignore-pattern \"**/dist\"",
    "format": "prettier --write \"agent/**/*.ts\" \"telegram-bot/**/*.ts\"",
    "format:check": "prettier --check \"agent/**/*.ts\" \"telegram-bot/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20"
  }
}
